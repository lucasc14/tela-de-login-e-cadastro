<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.app_com_interface.HelloController">
   <center>
      <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="Login">
               <font>
                  <Font name="Arial Bold" size="22.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="30.0" />
               </VBox.margin></Label>
            <TextField fx:id="txtUsuario" promptText="Usuário">
               <VBox.margin>
                  <Insets left="100.0" right="100.0" />
               </VBox.margin></TextField>
            <PasswordField fx:id="txtSenha" promptText="Senha">
               <VBox.margin>
                  <Insets left="100.0" right="100.0" />
               </VBox.margin></PasswordField>
            <HBox alignment="CENTER" prefHeight="26.0" prefWidth="400.0" spacing="35.0">
               <children>
                  <CheckBox mnemonicParsing="false" text="Lembrar senha" />
                  <Hyperlink fx:id="LinkCadastro" onAction="#irParaTelaCadastro" text="Criar conta" />
               </children>
            </HBox>
            <Button fx:id="btnLogin" mnemonicParsing="false" onAction="#onBtnLoginClick" style="-fx-background-color: #B89150; -fx-text-fill: white; -fx-background-radius: 4; -fx-font-family: arial; -fx-font-weight: bold; -fx-font-size: 14; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 5, 0, 0, 3);" text="Login" />
            <Label fx:id="labelLogin" textFill="#4bc657" />
         </children>
      </VBox>
   </center>
   <left>
      <Pane prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <ImageView fitHeight="400.0" fitWidth="200.0" pickOnBounds="true">
               <image>
                  <Image url="@../../../images/Logo_na_regua_app.jpeg" />
               </image>
            </ImageView>
         </children></Pane>
   </left>
</BorderPane>
