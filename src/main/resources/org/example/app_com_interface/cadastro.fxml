<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" stylesheets="@../../../css/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.app_com_interface.CadastroController">
   <center>
      <VBox alignment="TOP_CENTER">
         <children>
            <Label text="Crie sua conta">
               <font>
                  <Font name="Arial Bold" size="22.0" />
               </font>
               <padding>
                  <Insets bottom="10.0" top="30.0" />
               </padding>
               <VBox.margin>
                  <Insets top="30.0" />
               </VBox.margin>
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
            </Label>
            <TextField fx:id="txtNome" promptText="NOME" styleClass="campo-na-regua">
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
               <VBox.margin>
                  <Insets left="15.0" right="15.0" top="30.0" />
               </VBox.margin>
            </TextField>
            <TextField fx:id="txtEmail" layoutX="10.0" layoutY="36.0" promptText="EMAIL" styleClass="campo-na-regua">
               <VBox.margin>
                  <Insets left="15.0" right="15.0" top="15.0" />
               </VBox.margin>
            </TextField>
            <PasswordField fx:id="txtSenha" promptText="SENHA" styleClass="campo-na-regua">
               <VBox.margin>
                  <Insets left="15.0" right="15.0" top="15.0" />
               </VBox.margin>
            </PasswordField>
            <PasswordField fx:id="txtConfirmarSenha" layoutX="10.0" layoutY="141.0" promptText="CONFIRME SUA SENHA " styleClass="campo-na-regua">
               <VBox.margin>
                  <Insets left="15.0" right="15.0" top="15.0" />
               </VBox.margin>
            </PasswordField>
            <HBox alignment="BOTTOM_CENTER" prefHeight="100.0" prefWidth="200.0">
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
               <VBox.margin>
                  <Insets top="30.0" />
               </VBox.margin>
               <children>
                  <Button fx:id="btnVoltar" alignment="TOP_LEFT" mnemonicParsing="false" onAction="#voltarTela" text="VOLTAR">
                     <HBox.margin>
                        <Insets left="30.0" right="30.0" />
                     </HBox.margin>
                     <styleClass>
                        <String fx:value="button-secondary" />
                        <String fx:value="button-metal" />
                     </styleClass>
                  </Button>
                  <Button fx:id="btnCadastrar" alignment="CENTER" mnemonicParsing="false" onAction="#onCadastrar" text="CRIAR CONTA">
                     <HBox.margin>
                        <Insets left="100.0" right="30.0" />
                     </HBox.margin>
                     <styleClass>
                        <String fx:value="button-metal" />
                        <String fx:value="button-secondary" />
                     </styleClass>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="50.0" top="50.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </center>
</BorderPane>
